generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id             String    @id @default(uuid()) @db.Uuid
  homeTeam       String    @map("home_team")
  awayTeam       String    @map("away_team")
  opponentLogoUrl String?  @map("opponent_logo_url")
  whatsappUrl    String?   @map("whatsapp_url")
  matchDate      DateTime  @map("match_date") @db.Date
  matchTime      DateTime? @map("match_time") @db.Time(6)
  location       String?
  championshipId String?   @map("championship_id") @db.Uuid
  championshipName String? @map("championship_name")
  status         String    @default("Agendada")
  homeScore      Int?      @map("home_score")
  awayScore      Int?      @map("away_score")
  createdBy      String?   @map("created_by") @db.Uuid
  observations   String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  championship   Championship? @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  performances   PlayerMatchPerformance[]
  attendances    MatchAttendance[]
  lineup         MatchLineup?

  @@index([matchDate], map: "matches_match_date_idx")
  @@index([championshipId], map: "matches_championship_id_idx")
  @@map("matches")
}

model Championship {
  id          String    @id @default(uuid()) @db.Uuid
  teamName    String    @default("Torinno FC") @map("team_name")
  name        String
  imageUrl    String?   @map("image_url")
  season      String?
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  format      String?
  status      String    @default("futuro")
  officialUrl String?   @map("official_url")
  description String?
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  matches     Match[]

  @@index([teamName, status], map: "championships_team_status_idx")
  @@map("championships")
}

model UserProfile {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  nickname      String?
  email         String?   @unique
  role          String    @default("player")
  staffRole     String?   @map("staff_role")
  accountStatus String    @default("active") @map("account_status")
  avatarUrl     String?   @map("avatar_url")
  joinedAt      DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  playerProfile PlayerProfile?
  settings      UserSetting?

  @@index([role], map: "profiles_role_idx")
  @@map("profiles")
}

model PlayerProfile {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String?      @unique @map("user_id") @db.Uuid
  teamName     String       @default("Torinno FC") @map("team_name")
  fullName     String       @map("full_name")
  nickname     String
  position     String
  shirtNumber  Int          @map("shirt_number")
  dominantFoot String?      @map("dominant_foot")
  bio          String?
  status       String       @default("Ativo")
  instagram    String?
  avatarUrl    String?      @map("avatar_url")
  photoUrl     String?      @map("photo_url")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  user         UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  stats        PlayerStats?
  performances PlayerMatchPerformance[]
  achievements PlayerAchievement[]
  attendances   MatchAttendance[]
  lineupPlayers MatchLineupPlayer[]

  @@index([teamName, status], map: "player_profiles_team_status_idx")
  @@index([userId], map: "player_profiles_user_id_idx")
  @@map("player_profiles")
}

model PlayerStats {
  id             String        @id @default(uuid()) @db.Uuid
  playerId       String        @unique @map("player_id") @db.Uuid
  goals          Int           @default(0)
  assists        Int           @default(0)
  ballRecoveries Int           @default(0) @map("ball_recoveries")
  shots          Int           @default(0)
  accuratePasses Int           @default(0) @map("accurate_passes")
  tackles        Int           @default(0)
  interceptions  Int           @default(0)
  matches        Int           @default(0)
  wins           Int           @default(0)
  draws          Int           @default(0)
  losses         Int           @default(0)
  yellowCards    Int           @default(0) @map("yellow_cards")
  redCards       Int           @default(0) @map("red_cards")
  averageRating  Decimal       @default(0) @map("average_rating") @db.Decimal(3, 1)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  player         PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

model PlayerMatchPerformance {
  id             String        @id @default(uuid()) @db.Uuid
  playerId       String        @map("player_id") @db.Uuid
  matchId        String        @map("match_id") @db.Uuid
  goals          Int           @default(0)
  assists        Int           @default(0)
  ballRecoveries Int           @default(0) @map("ball_recoveries")
  shots          Int           @default(0)
  accuratePasses Int           @default(0) @map("accurate_passes")
  tackles        Int           @default(0)
  interceptions  Int           @default(0)
  yellowCards    Int           @default(0) @map("yellow_cards")
  redCards       Int           @default(0) @map("red_cards")
  minutesPlayed  Int           @default(0) @map("minutes_played")
  rating         Decimal       @default(0) @db.Decimal(3, 1)
  notes          String?
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  player         PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match          Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId], map: "player_match_performances_player_match_key")
  @@index([matchId], map: "player_match_performances_match_id_idx")
  @@index([createdBy], map: "player_match_performances_created_by_idx")
  @@map("player_match_performances")
}

model Achievement {
  id          String              @id @default(uuid()) @db.Uuid
  key         String              @unique
  name        String
  description String
  icon        String              @default("star")
  category    String              @default("performance")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  players     PlayerAchievement[]

  @@map("achievements")
}

model PlayerAchievement {
  id            String        @id @default(uuid()) @db.Uuid
  playerId      String        @map("player_id") @db.Uuid
  achievementId String        @map("achievement_id") @db.Uuid
  unlockedAt    DateTime      @default(now()) @map("unlocked_at") @db.Timestamptz(6)
  metadata      Json?
  player        PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
  achievement   Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([playerId, achievementId], map: "player_achievements_player_achievement_key")
  @@index([achievementId], map: "player_achievements_achievement_id_idx")
  @@map("player_achievements")
}

model MatchAttendance {
  id          String        @id @default(uuid()) @db.Uuid
  matchId     String        @map("match_id") @db.Uuid
  playerId    String        @map("player_id") @db.Uuid
  status      String
  notes       String?
  respondedAt DateTime?     @map("responded_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  match       Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId], map: "match_attendances_match_player_key")
  @@index([playerId, status], map: "match_attendances_player_status_idx")
  @@map("match_attendances")
}

model MatchLineup {
  id         String              @id @default(uuid()) @db.Uuid
  matchId    String              @unique @map("match_id") @db.Uuid
  formation  String              @default("4-3-3")
  captainId  String?             @map("captain_id") @db.Uuid
  createdBy  String?             @map("created_by") @db.Uuid
  notes      String?
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  match      Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  players    MatchLineupPlayer[]

  @@map("match_lineups")
}

model MatchLineupPlayer {
  id       String        @id @default(uuid()) @db.Uuid
  lineupId String        @map("lineup_id") @db.Uuid
  playerId String        @map("player_id") @db.Uuid
  role     String
  position String?
  sortOrder Int          @default(0) @map("sort_order")
  lineup   MatchLineup   @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player   PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([lineupId, playerId], map: "match_lineup_players_lineup_player_key")
  @@index([playerId], map: "match_lineup_players_player_id_idx")
  @@map("match_lineup_players")
}

model ActivityLog {
  id                String   @id @default(uuid()) @db.Uuid
  type              String
  actorId           String?  @map("actor_id") @db.Uuid
  actorName         String?  @map("actor_name")
  message           String
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id") @db.Uuid
  actionUrl         String?  @map("action_url")
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "activity_logs_created_at_idx")
  @@index([relatedEntityType, relatedEntityId], map: "activity_logs_related_idx")
  @@map("activity_logs")
}

model UserSetting {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @unique @map("user_id") @db.Uuid
  data      Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model ClubSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("club_settings")
}

model RolePermission {
  id            String   @id @default(uuid()) @db.Uuid
  role          String
  permissionKey String   @map("permission_key")
  enabled       Boolean  @default(false)
  updatedBy     String?  @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([role, permissionKey], map: "role_permissions_role_key")
  @@index([role], map: "role_permissions_role_idx")
  @@map("role_permissions")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  targetId    String?  @map("target_id") @db.Uuid
  action      String
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([targetId, createdAt], map: "admin_audit_logs_target_idx")
  @@map("admin_audit_logs")
}

model Notification {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String?   @map("user_id") @db.Uuid
  userEmail         String?   @map("user_email")
  teamName          String    @default("Torinno FC") @map("team_name")
  type              String
  title             String
  message           String
  relatedEntityType String?   @map("related_entity_type")
  relatedEntityId   String?   @map("related_entity_id") @db.Uuid
  actionUrl         String?   @map("action_url")
  isRead            Boolean   @default(false) @map("is_read")
  readAt            DateTime? @map("read_at") @db.Timestamptz(6)
  metadata          Json?
  scheduledFor      DateTime? @map("scheduled_for") @db.Timestamptz(6)
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  status            String    @default("sent")
  matchId           String?   @map("match_id") @db.Uuid
  reminderType      String?   @map("reminder_type")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([userEmail, type, relatedEntityType, relatedEntityId, reminderType], map: "notifications_dedupe_idx")
  @@index([userEmail, isRead, createdAt], map: "notifications_user_read_idx")
  @@index([status, scheduledFor], map: "notifications_scheduled_idx")
  @@map("notifications")
}

model NotificationPreference {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String?  @map("user_id") @db.Uuid
  userEmail             String   @unique @map("user_email")
  matchCreated          Boolean  @default(true) @map("match_created")
  matchUpdated          Boolean  @default(true) @map("match_updated")
  matchReminder24h      Boolean  @default(true) @map("match_reminder_24h")
  matchReminder1h       Boolean  @default(true) @map("match_reminder_1h")
  championships         Boolean  @default(true)
  newMembers            Boolean  @default(true) @map("new_members")
  statistics            Boolean  @default(true)
  administration        Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("notification_preferences")
}

model Tryout {
  id           String    @id @default(uuid()) @db.Uuid
  teamName     String    @default("Torinno FC") @map("team_name")
  title        String
  overall      Int?
  tryoutDate   DateTime  @map("tryout_date") @db.Date
  tryoutTime   DateTime? @map("tryout_time") @db.Time(6)
  location     String?
  category     String    @default("Geral")
  contact      String?
  requirements String?
  observations String?
  status       String    @default("Agendada")
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([teamName, status], map: "tryouts_team_status_idx")
  @@map("tryouts")
}

model NotificationLog {
  id           String    @id @default(uuid()) @db.Uuid
  eventType    String    @map("event_type")
  entityId     String    @map("entity_id") @db.Uuid
  channel      String    @default("whatsapp")
  destination  String
  status       String    @default("pending")
  messageBody  String    @map("message_body")
  apiResponse  Json?     @map("api_response")
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([eventType, entityId, channel, destination])
  @@index([eventType, entityId, channel, destination], map: "notification_logs_lookup_idx")
  @@index([status, createdAt], map: "notification_logs_status_idx")
  @@map("notification_logs")
}
