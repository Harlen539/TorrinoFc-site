PORT=4000
CORS_ORIGIN=http://localhost:5173
# Legado opcional: nao exponha em variaveis VITE_* no frontend.
ADMIN_API_KEY=

DATABASE_URL=postgresql://postgres.cvhggeakriafznoevjsd:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.cvhggeakriafznoevjsd:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Supabase Pooler:
# - DATABASE_URL usa Transaction pooler, porta 6543, para a API em runtime.
# - DIRECT_URL usa Session pooler, porta 5432, para Prisma migrations.
# - O usuario do pooler precisa ser postgres.<project-ref>, nao apenas postgres.
# - Se a senha tiver caracteres especiais (#, @, %, /, ? etc), gere a URL no painel
#   do Supabase ou codifique a senha para URL.

SUPABASE_URL=https://cvhggeakriafznoevjsd.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://cvhggeakriafznoevjsd.supabase.co/auth/v1/.well-known/jwks.json

WHATSAPP_NOTIFICATION_MODE=manual
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GROUP_ID=
WHATSAPP_API_VERSION=v22.0

# Para envio automatico oficial, troque para WHATSAPP_NOTIFICATION_MODE=cloud_api
# e preencha as variaveis da WhatsApp Business Platform / Cloud API.
#
# Alternativa oficial caso a conta nao tenha Groups API:
# lista separada por virgula com numeros autorizados, ex: 5585999999999,5585888888888
WHATSAPP_ADMIN_RECIPIENTS=

# SMTP/Gmail para envio de e-mails do backend.
# Para Gmail, ative verificacao em duas etapas na conta Google e crie uma "Senha de app".
# Nao use a senha normal da conta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-do-google
EMAIL_FROM_NAME=Torinno FC
EMAIL_FROM_ADDRESS=seu-email@gmail.com
